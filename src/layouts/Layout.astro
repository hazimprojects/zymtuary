---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	immersive?: boolean;
}

const {
	title = 'Zymtuary Mythos',
	description = 'An interactive narrative experience.',
	immersive = false,
} = Astro.props;

const bodyClass = immersive
	? 'min-h-dvh bg-black text-[#f5f0e8] antialiased'
	: 'min-h-dvh bg-zinc-950 text-zinc-100 antialiased';
---

<!doctype html>
<html lang={immersive ? 'ms' : 'en'}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<link rel="apple-touch-icon" href="/icon-192.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#000000" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Zymtuary" />
		<title>{title}</title>
		{immersive ? (
			<>
				<link rel="preconnect" href="https://fonts.googleapis.com" />
				<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
				<link
					href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400&display=swap"
					rel="stylesheet"
				/>
			</>
		) : null}
	</head>
	<body class={bodyClass}>
		<slot />
		<script>
			// Chrome perlu service worker berdaftar (bukan sekadar manifest) sebelum
			// ia anggap laman ini "installable" penuh — tanpanya, "Add to Home
			// Screen" jatuh balik ke pintasan biasa (ikon huruf generik), bukan
			// pemasangan app sebenar dengan orientation lock.
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js').catch(() => {});
				});
			}
		</script>
	</body>
</html>
