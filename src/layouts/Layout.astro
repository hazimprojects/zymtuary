---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	immersive?: boolean;
}

const {
	title = 'Zymtuary Mythos',
	description = 'An interactive narrative experience.',
	immersive = false,
} = Astro.props;

const bodyClass = immersive
	? 'min-h-dvh overflow-hidden bg-black text-[#f5f0e8] antialiased'
	: 'min-h-dvh bg-zinc-950 text-zinc-100 antialiased';
---

<!doctype html>
<html lang={immersive ? 'ms' : 'en'}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class={bodyClass}>
		<slot />
	</body>
</html>
