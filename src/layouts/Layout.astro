---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	immersive?: boolean;
}

const {
	title = 'Zymtuary Mythos',
	description = 'An interactive narrative experience.',
	immersive = false,
} = Astro.props;

const bodyClass = immersive
	? 'min-h-dvh bg-black text-[#f5f0e8] antialiased'
	: 'min-h-dvh bg-zinc-950 text-zinc-100 antialiased';
---

<!doctype html>
<html lang={immersive ? 'ms' : 'en'}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{immersive ? (
			<>
				<link rel="preconnect" href="https://fonts.googleapis.com" />
				<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
				<link
					href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400&display=swap"
					rel="stylesheet"
				/>
			</>
		) : null}
	</head>
	<body class={bodyClass}>
		<slot />
	</body>
</html>
