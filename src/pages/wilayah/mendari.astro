---
import Layout from '../../layouts/Layout.astro';
import zipModel from '../../data/zip-model.json';

const wilayah = zipModel.wilayah.find((w) => w.id === 'mendari');
if (!wilayah) throw new Error('Wilayah "mendari" tidak dijumpai dalam zip-model.json');
---

<Layout title={`${wilayah.nama} · Zymtuary`} immersive>
	<main class="flex min-h-dvh flex-col items-center justify-center gap-4 px-8 text-center">
		<p class="font-body text-[0.65rem] uppercase tracking-[0.32em] text-[#f5f0e8]/45">{wilayah.nama}</p>
		<p class="font-display max-w-sm text-lg font-light leading-relaxed text-[#f5f0e8]/70">
			Peta wilayah ini sedang dibina semula dalam bentuk baharu.
		</p>
		<a href="/" class="pointer-events-auto mt-4 font-body text-[0.6rem] uppercase tracking-[0.3em] text-[#f5f0e8]/55 transition-colors active:text-[#f5f0e8]/85">
			← Kembali
		</a>
	</main>
</Layout>
