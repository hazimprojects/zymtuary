---
import Layout from '../../layouts/Layout.astro';
import VeilroseQuarterVN from '../../components/scenes/VeilroseQuarterVN';
import zipModel from '../../data/zip-model.json';

const entity = zipModel.entities.find((e) => e.id === 'zymelisse');
if (!entity) throw new Error('Entiti "zymelisse" (Veilrose Quarter) tidak dijumpai dalam zip-model.json');
---

<Layout title={`${entity.kawasan} · Zymtuary`} immersive>
	<VeilroseQuarterVN client:load />
</Layout>
