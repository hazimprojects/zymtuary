---
import Layout from '../layouts/Layout.astro';
import EntranceExperience from '../components/entities/EntranceExperience';
import zipModel from '../data/zip-model.json';

const { garden_keeper, meta } = zipModel;
const gardenKeeperLine = 'Kau tidak perlu tahu ke mana kau pergi. Cukup berjalan.';
---

<Layout title="Zymtuary" description={meta.zipModelNote} immersive>
	<EntranceExperience client:load gardenKeeperLine={gardenKeeperLine} />
</Layout>
