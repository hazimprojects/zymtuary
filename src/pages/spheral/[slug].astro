---
import Layout from '../../layouts/Layout.astro';
import SpheralExperience from '../../components/entities/SpheralExperience';
import LuminaraExperience from '../../components/spherals/LuminaraExperience';
import zipModel from '../../data/zip-model.json';

export function getStaticPaths() {
	return zipModel.spherals.map((spheral) => ({
		params: { slug: spheral.id },
		props: {
			spheral,
			entities: zipModel.entities.filter((e) => e.spheral_rumah === spheral.id),
			wilayah: zipModel.wilayah.filter((w) => w.spheral_induk === spheral.id),
		},
	}));
}

const { spheral, entities, wilayah } = Astro.props;
const isLuminara = spheral.id === 'luminara';
---

<Layout title={`${spheral.nama} · Zymtuary`} immersive>
	{
		isLuminara ? (
			<LuminaraExperience client:load spheral={spheral} entities={entities} />
		) : (
			<SpheralExperience client:load spheral={spheral} entities={entities} wilayah={wilayah} />
		)
	}
</Layout>
